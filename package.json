{
  "name": "tekto",
  "version": "0.2.0",
  "description": "Computational geometry toolkit — interactive 3D generation, analysis, and visualization (meshes, curves, NURBS, SDF, voxels, graphs, BIM/IFC)",
  "main": "dist/index.js",
  "module": "dist/index.mjs",
  "types": "dist/index.d.ts",
  "files": [
    "dist",
    "src"
  ],
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.mjs",
      "require": "./dist/index.js"
    },
    "./react": {
      "types": "./dist/react.d.ts",
      "import": "./dist/react.mjs",
      "require": "./dist/react.js"
    }
  },
  "scripts": {
    "prepare":       "npm run build",
    "build":         "tsup src/index.ts src/react.ts --format cjs,esm --dts --external three --external react --external react-dom --external web-ifc",
    "dev":           "tsup src/index.ts src/react.ts --format cjs,esm --dts --watch --external three --external react --external react-dom --external web-ifc",
    "lint":          "tsc --noEmit -p tsconfig.lint.json",
    "test":          "vitest run",
    "test:watch":    "vitest",
    "test:coverage": "vitest run --coverage",
    "playground":    "vite playground"
  },
  "peerDependencies": {
    "react": ">=18.0.0",
    "react-dom": ">=18.0.0",
    "three": ">=0.150.0",
    "web-ifc": ">=0.0.44"
  },
  "peerDependenciesMeta": {
    "react": {
      "optional": true
    },
    "react-dom": {
      "optional": true
    },
    "three": {
      "optional": true
    },
    "web-ifc": {
      "optional": true
    }
  },
  "devDependencies": {
    "@types/react": "^18.3.28",
    "@types/react-dom": "^18.3.7",
    "@types/three": "^0.160.0",
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "three": "^0.183.1",
    "tsup": "^8.0.0",
    "typescript": "^5.3.0",
    "vitest": "^2.0.0",
    "web-ifc": "^0.0.77"
  },
  "keywords": [
    "computational-geometry",
    "mesh",
    "nurbs",
    "sdf",
    "voxel",
    "bim",
    "ifc",
    "threejs",
    "react",
    "interactive",
    "visualization",
    "algorithms",
    "subdivision",
    "convex-hull",
    "triangulation"
  ],
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/modellstadt/tekto.git"
  }
}
